# Database Connection URL for NeonDB
DATABASE_URL="postgresql://neondb_owner:your_password_here@your_neon_db_url_here/neondb?sslmode=require&channel_binding=require"

# Better Auth URL for Authentication
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000" # ใช้สำหรับ Client-side
BETTER_AUTH_URL="http://localhost:3000" # ใช้สำหรับ Server-side

# GitHub OAuth
GITHUB_CLIENT_ID="your_github_client_id_here"
GITHUB_CLIENT_SECRET="your_github_client_secret_here"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# LINE Login
LINE_CLIENT_ID="your_line_client_id_here"
LINE_CLIENT_SECRET="your_line_client_secret_here"

# Facebook Login
FACEBOOK_CLIENT_ID="your_facebook_client_id_here"
FACEBOOK_CLIENT_SECRET="your_facebook_client_secret_here"

# Admin Email (ใช้สำหรับกำหนดผู้ใช้ที่เป็นแอดมิน)
ADMIN_EMAIL="admin@ainative.com"

# SMTP Configuration for Sending Emails (เช่น สำหรับ 2FA)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-app-password-here" # แนะนำให้ใช้ App Password แทนรหัสผ่านจริงของ Gmail เพื่อความปลอดภัย

# OpenAI API Key
OPENAI_API_KEY="your_openai_api_key_here"

# Embedding Model
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"